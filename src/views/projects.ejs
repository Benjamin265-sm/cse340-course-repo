<h2>Upcoming Service Projects</h2>

<% if (projects && projects.length) { %>
  <ul>
    <% projects.forEach(project => { %>
      <li>
        <strong><%= project.title %></strong> –
        <%= project.description %>
        <% if (project.location) { %>
          (<%= project.location %>)
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No service projects available.</p>
<% } %>